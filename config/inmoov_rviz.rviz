# Minimal portable RViz config for InMoov/Lucy robot.
# Window Geometry only sets dock visibility (no fixed size/position) so the
# layout still adapts to any screen. RobotModel uses /robot_description topic.
# Fixed Frame must be base_node (root link) so the full TF tree connects.

Panels:
  - Class: rviz_common/Displays
    Name: Displays
  - Class: rviz_common/Views
    Name: Views

# Start with the left dock (Displays/Views) folded so the 3D view gets the
# full width. Click the small arrow on the left edge to expand it again.
# No Width/Height/X/Y here so the window still adapts to any screen.
Window Geometry:
  Hide Left Dock: true
  Hide Right Dock: false

Visualization Manager:
  Class: rviz_common/VisualizationManager
  # Toolbar tools. MoveCamera is required to rotate/pan/zoom with the mouse;
  # without an explicit Tools list some RViz builds load only Interact.
  Tools:
    - Class: rviz_default_plugins/MoveCamera
    - Class: rviz_default_plugins/Interact
      Hide Inactive Objects: true
    - Class: rviz_default_plugins/Select
    - Class: rviz_default_plugins/FocusCamera
    - Class: rviz_default_plugins/Measure
      Line color: 128; 128; 0
  Displays:
    - Class: rviz_default_plugins/Grid
      Enabled: true
      Name: Grid
    - Alpha: 1
      Class: rviz_default_plugins/RobotModel
      Collision Enabled: false
      Description Source: Topic
      Description Topic: /robot_description
      Enabled: true
      Name: RobotModel (Visual)
      TF Prefix: ""
      Update Interval: 0
      Value: true
      Visual Enabled: true
    # Translucent collision overlay so primitives/mesh collisions are visible
    # on top of the visual meshes. Toggle this display off (or check
    # "Collision Enabled" on the visual one) to see only one at a time.
    - Alpha: 0.4
      Class: rviz_default_plugins/RobotModel
      Collision Enabled: true
      Description Source: Topic
      Description Topic: /robot_description
      Enabled: true
      Name: RobotModel (Collision)
      TF Prefix: ""
      Update Interval: 0
      Value: true
      Visual Enabled: false
    - Class: rviz_default_plugins/TF
      Enabled: false
      Name: TF
  Global Options:
    Fixed Frame: base_node
    Frame Rate: 30
  Name: root
  Transformation:
    Current:
      Class: rviz_default_plugins/TF
  Views:
    # Switch view from the Views panel ▸ Type dropdown, or pick a saved view below.
    # Tip: FPS is a free-fly camera (WASD + drag-look). Orbit/XYOrbit rotate around
    # a focal point. ThirdPersonFollower locks onto a TF frame.
    Current:
      Class: rviz_default_plugins/XYOrbit
      Distance: 2.4
      Focal Point:
        X: 0
        Y: 0
        Z: 0.85
      Name: Current View
      Pitch: 0.4
      Yaw: 5
    Saved:
      - Class: rviz_default_plugins/FPS
        Name: FPS (free fly)
        Position:
          X: 3.0
          Y: 0.0
          Z: 1.4
        Pitch: 0.0
        Yaw: 3.14159
      - Class: rviz_default_plugins/Orbit
        Name: Orbit (free rotation)
        Distance: 2.4
        Focal Point:
          X: 0
          Y: 0
          Z: 0.85
        Pitch: 0.4
        Yaw: 5
      - Class: rviz_default_plugins/TopDownOrtho
        Name: Top-down (ortho)
        Scale: 200
        X: 0
        Y: 0
        Angle: 0
