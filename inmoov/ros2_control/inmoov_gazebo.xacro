<?xml version="1.0"?>
<!-- Gazebo plugin for gz_ros2_control: runs controller_manager inside Gazebo and drives simulated joints.
     Expects controller_config arg from parent (inmoov.urdf.xacro). -->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <!-- Fix entire stand to the world so the robot does not fall (gz-sim may still move root; heavy mass in URDF is fallback). -->
  <gazebo reference="base_node">
    <static>true</static>
  </gazebo>
  <gazebo reference="stand_link">
    <static>true</static>
  </gazebo>

  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(arg controller_config)</parameters>
      <!-- Empty namespace so controller topics stay at /left_arm_controller, /right_arm_controller (panel expects these). -->
      <namespace></namespace>
    </plugin>
  </gazebo>
</robot>
